#!/bin/bash
#--------------------------------------------------------------------------------
if [ "${1}" == "all" ]
then
	#--------------------------------------------------------------------------------
	find /www/ -type d \( -name ".zig-cache" -o -name ".zig-out" -o -name "zig-cache" -o -name "zig-out" \) -exec echo "rm -rf {}" \; -exec rm -rf {} +
	#--------------------------------------------------------------------------------
else
	#--------------------------------------------------------------------------------
	find /www/c/ -type d \( -name ".zig-cache" -o -name ".zig-out" -o -name "zig-cache" -o -name "zig-out" \) -exec echo "rm -rf {}" \; -exec rm -rf {} +
	find /www/wasm/ -type d \( -name ".zig-cache" -o -name ".zig-out" -o -name "zig-cache" -o -name "zig-out" \) -exec echo "rm -rf {}" \; -exec rm -rf {} +
	find /www/zig/ -type d \( -name ".zig-cache" -o -name ".zig-out" -o -name "zig-cache" -o -name "zig-out" \) -exec echo "rm -rf {}" \; -exec rm -rf {} +
	find /www/zig015/ -type d \( -name ".zig-cache" -o -name ".zig-out" -o -name "zig-cache" -o -name "zig-out" \) -exec echo "rm -rf {}" \; -exec rm -rf {} +
	#--------------------------------------------------------------------------------
fi
#--------------------------------------------------------------------------------