#!/bin/bash
#--------------------------------------------------------------------------------
export ZIG_BUILD_MODE=Debug
#--------------------------------------------------------------------------------
if [ -f "Taskfile.yml" ] || [ -f "Taskfile.yaml" ] || [ -f "taskfile.yml" ] || [ -f "taskfile.yaml" ]
then
	task debug -- "$@"
	exit $?
fi
#--------------------------------------------------------------------------------
zigbuild "$@"
exit $?
#--------------------------------------------------------------------------------
