#!/bin/bash
#--------------------------------------------------------------------------------
#################################################################################
#--------------------------------------------------------------------------------
ZIG=$( [[ $PWD == */zig015/* ]] && echo -n "/usr/local/bin/zig015" || echo -n "/usr/local/bin/zig" )
#--------------------------------------------------------------------------------
LC=""; match_libc() { grep -qE '@?cImport|@c(Include|Define|Undef|Struct|Union)|\bstd\.c\b|@import\("std"\)\.c' "$1"; }
#--------------------------------------------------------------------------------
#################################################################################
#--------------------------------------------------------------------------------
source $(dirname ${BASH_SOURCE[0]})/zigbuild-env-vars
[ "${ZIG_RUN_MODE}" == "" ] && ZIG_RUN_MODE="ReleaseSmall"
#--------------------------------------------------------------------------------
#################################################################################
#--------------------------------------------------------------------------------
BASENAME=$(basename "$(pwd)")
#--------------------------------------------------------------------------------
ZIG_FILE_COUNT=$(find . -type f -name "*.zig" | wc -l)
#--------------------------------------------------------------------------------
SOURCE=""
#--------------------------------------------------------------------------------
#################################################################################
#--------------------------------------------------------------------------------
if [ "${1}" != "" ]
then
	#----------------------------------------
	if [ "${1}" == "build.zig" ]
	then
		#----------------------------------------
		shift
		${ZIG} build run -- "$@"
		exit $?
		#----------------------------------------
	elif [ -f "${1}" ]
	then
		#----------------------------------------
		SOURCE=${1}; shift
		#----------------------------------------
		# match_libc ${SOURCE} && LC="-lc"
		#----------------------------------------
		${ZIG} run ${SOURCE} ${LC} -O ${ZIG_RUN_MODE} -- "$@"
		#----------------------------------------
	else
		#----------------------------------------
		echo "invalid source filename: ${SOURCE}"
		exit 1
		#----------------------------------------
	fi
	#--------------------------------------------------------------------------------
	exit $?
	#--------------------------------------------------------------------------------
fi
#--------------------------------------------------------------------------------
#################################################################################
#--------------------------------------------------------------------------------
if [ -f "Taskfile.yml" ] || [ -f "Taskfile.yaml" ] || [ -f "taskfile.yml" ] || [ -f "taskfile.yaml" ]
then
	#----------------------------------------
	if task --list-all | grep -qE 'run:'
	then
		task run -- "$@"
		exit $?
	fi
	#----------------------------------------
fi
#--------------------------------------------------------------------------------
#################################################################################
#--------------------------------------------------------------------------------
if [ "${ZIG_FILE_COUNT}" -eq 2 ] && [ -f "root.zig" ] && [ -f "main.zig" ]
then
	#----------------------------------------
	$(dirname ${BASH_SOURCE[0]})/zigbuild-run "$@"
	exit $?
	#----------------------------------------
fi
#--------------------------------------------------------------------------------
#################################################################################
#--------------------------------------------------------------------------------
if [ -f "build.zig" ]
then
	#----------------------------------------
	[ -f main.zig ] || { echo "main.zig does not exists"; exit 1; }
	#----------------------------------------
	${ZIG} build run -- "$@"
	exit $?
	#----------------------------------------
elif [ -f "main.zig" ]
then
	#----------------------------------------
	SOURCE="main.zig"
	#----------------------------------------
elif [ -f "root.zig" ]
then
	#----------------------------------------
	SOURCE="root.zig"
	#----------------------------------------
else
	#----------------------------------------
	if [ -f "${BASENAME}.zig" ]
	then
		#----------------------------------------
		SOURCE="${BASENAME}.zig"
		#----------------------------------------
	else
		#----------------------------------------
		echo "unknown source filename"
		exit 1
		#----------------------------------------
	fi
	#----------------------------------------
fi
#--------------------------------------------------------------------------------
#################################################################################
#--------------------------------------------------------------------------------
if [ -f "${SOURCE}" ]
then
	#----------------------------------------
	# match_libc ${SOURCE} && LC="-lc"
	#----------------------------------------
	${ZIG} run ${SOURCE} ${LC} -O ${ZIG_RUN_MODE} -- "$@"
	#----------------------------------------
else
	#----------------------------------------
	echo "unknown source filename"
	#----------------------------------------
fi
#--------------------------------------------------------------------------------
exit $?
#--------------------------------------------------------------------------------
#################################################################################
#--------------------------------------------------------------------------------

